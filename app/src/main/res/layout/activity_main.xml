<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gv_primary"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/frame_layout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/barrier_bottom_menus" />

    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier_bottom_menus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="top"
        app:constraint_referenced_ids="bottomAppBarContainer,bottomNavigationClient" />

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/bottomAppBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.bottomappbar.BottomAppBar
            android:id="@+id/bottomAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:backgroundTint="@color/gv_bottom_bar"
            android:visibility="gone"
            app:fabAlignmentMode="center"
            app:fabCradleMargin="8dp"
            app:fabCradleRoundedCornerRadius="32dp"
            app:fabCradleVerticalOffset="50dp"
            app:hideOnScroll="false"
            app:paddingBottomSystemWindowInsets="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.bottomnavigation.BottomNavigationView
                    android:id="@+id/bottomNavigationLeft"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    app:itemIconTint="@color/nav_item_color"
                    app:itemTextColor="@color/nav_item_color"
                    app:labelVisibilityMode="labeled"
                    app:menu="@menu/bottom_menu_left" />

                <View
                    android:id="@+id/buttonContainer"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.8" />

                <com.google.android.material.bottomnavigation.BottomNavigationView
                    android:id="@+id/bottomNavigationRight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    app:itemIconTint="@color/nav_item_color"
                    app:itemTextColor="@color/nav_item_color"
                    app:labelVisibilityMode="labeled"
                    app:menu="@menu/bottom_menu_right" />

            </LinearLayout>
        </com.google.android.material.bottomappbar.BottomAppBar>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/gv_accent"
            android:src="@drawable/ic_baseline_add_24"
            android:tint="@color/white"
            android:visibility="gone"
            app:borderWidth="0dp"
            app:layout_anchor="@id/bottomAppBar"
            app:layout_anchorGravity="top"
            app:maxImageSize="28dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationClient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/gv_bottom_bar"
        android:visibility="gone"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>