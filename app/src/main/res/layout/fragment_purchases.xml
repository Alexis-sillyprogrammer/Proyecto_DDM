<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gv_primary"
    tools:context=".fragments.PurchasesFragment">

    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gv_surface"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/purchases_title"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/gv_on_surface" />

        <TextView
            android:id="@+id/tvOrderCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 pedidos"
            android:textSize="12sp"
            android:textColor="@color/gv_accent"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/bg_count_badge" />

    </LinearLayout>

    <View
        android:id="@+id/vDivider"
        android:layout_width="0dp"
        android:layout_height="0.5dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <HorizontalScrollView
        android:id="@+id/hsvFilter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/gv_surface"
        android:paddingHorizontal="12dp"
        android:paddingBottom="10dp"
        android:paddingTop="6dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/llHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                style="@style/GvChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/filter_all"
                android:textColor="@color/chip_text_selector"
                app:chipBackgroundColor="@color/chip_background_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipDelivered"
                style="@style/GvChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_delivered"
                android:textColor="@color/chip_text_selector"
                app:chipBackgroundColor="@color/chip_background_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipInProcess"
                style="@style/GvChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_in_progress"
                android:textColor="@color/chip_text_selector"
                app:chipBackgroundColor="@color/chip_background_selector" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPending"
                style="@style/GvChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_pending"
                android:textColor="@color/chip_text_selector"
                app:chipBackgroundColor="@color/chip_background_selector" />

        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPurchases"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/hsvFilter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/llEmpty"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/hsvFilter"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_baseline_home_24"
            android:contentDescription="Sin pedidos"
            app:tint="#1E2A45" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/purchases_empty"
            android:textColor="@color/gv_icon_inactive"
            android:textSize="15sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>