<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gv_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:id="@+id/flPurchases"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:background="@color/gv_surface" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal" >

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabBackPurchases"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_outline_arrow_left_24"
                    app:fabCustomSize="48dp"
                    app:maxImageSize="24dp"
                    app:backgroundTint="@color/gv_accent"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="6dp"
                    android:text="Detalle del pedido"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvOrderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:text="Entregado"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:background="@drawable/bg_status_delivered" />

            </LinearLayout>

        </FrameLayout>

        <FrameLayout
            android:id="@+id/flCatalog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="visible">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabBackCatalog"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_outline_arrow_left_24"
                android:layout_marginTop="16dp"
                android:layout_marginStart="16dp"
                app:fabCustomSize="48dp"
                app:maxImageSize="24dp"
                app:backgroundTint="@color/gv_accent"
                app:tint="@color/white" />

        </FrameLayout>

        <FrameLayout
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_icon_box_large">

            <ImageView
                android:id="@+id/ivDetailProduct"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_baseline_home_24"
                android:contentDescription="Imagen del producto"
                app:tint="@color/gv_icon_inactive" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="24dp"
            android:text="Nombre del producto"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/gv_on_surface"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvDetailCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:text="Videojuego"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingHorizontal="14dp"
            android:paddingVertical="4dp"
            android:background="@drawable/bg_icon_box"
            android:textColor="@color/gv_icon_inactive" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/gv_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#14FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/section_general"
                    android:textSize="11sp"
                    android:textColor="@color/gv_accent"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/tvDetailDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:text="Descripción del producto."
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.5"
                    android:textColor="@color/gv_on_surface"
                    android:padding="12dp"
                    android:background="@drawable/bg_icon_box" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginBottom="14dp"
                    android:background="#12FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/hint_price"
                        android:textSize="12sp"
                        android:textColor="@color/gv_icon_inactive"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/tvDetailPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="$0.00"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/gv_accent" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOrderInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="24dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/gv_surface"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeColor="#14FFFFFF"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:text="@string/section_price"
                    android:textSize="11sp"
                    android:textColor="@color/gv_accent"
                    android:textAllCaps="true"
                    android:letterSpacing="0.1" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="N.° de pedido"
                        android:textSize="12sp"
                        android:textColor="@color/gv_icon_inactive" />

                    <TextView
                        android:id="@+id/tvDetailOrderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="#GV-0001"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/gv_on_surface" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cantidad"
                        android:textSize="12sp"
                        android:textColor="@color/gv_icon_inactive" />

                    <TextView
                        android:id="@+id/tvDetailQty"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="x1"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/gv_on_surface" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:layout_marginVertical="8dp"
                    android:background="#12FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Fecha de recogida"
                        android:textSize="12sp"
                        android:textColor="@color/gv_icon_inactive" />

                    <TextView
                        android:id="@+id/tvDetailDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10/06/2026"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/gv_on_surface" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>