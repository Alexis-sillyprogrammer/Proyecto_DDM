<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="80dp"
    android:layout_height="88dp"
    android:layout_marginHorizontal="4dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/gv_highlight"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:strokeColor="#14FFFFFF"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp">

        <ImageView
            android:id="@+id/ivFavProduct"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_baseline_home_24"
            android:contentDescription="Producto favorito"
            app:tint="@color/gv_icon_inactive" />

        <TextView
            android:id="@+id/tvFavName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:maxLines="2"
            android:text="Nombre"
            android:textColor="@color/gv_on_surface"
            android:textSize="9sp"
            android:ellipsize="end" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>